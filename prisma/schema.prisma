generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// ENUMS
// =============================================

enum UserRole {
  USER
  SELLER
  ADMIN
}

enum AuthProvider {
  local
  google
  facebook
  github
}

enum TokenType {
  refresh
  emailVerification
  passwordReset
}

enum AuctionStatus {
  upcoming
  active
  ended
  sold
  cancelled
}

enum SellerRequestStatus {
  pending
  approved
  rejected
}

enum PaymentStatus {
  pending
  success
  failed
  refunded
}

enum ReactionType {
  like
  love
  smile
  wow
  flag
}

enum ReportStatus {
  pending
  reviewed
  resolved
  dismissed
}

enum ActivityType {
  bid_placed
  auction_won
  payment_made
  profile_updated
  auction_created
  watched_auction
  seller_request_submitted
}

enum TransactionType {
  deposit
  withdrawal
  bid_hold
  bid_refund
  auction_payment
  service_fee
}

// =============================================
// USERS & IDENTITY
// =============================================

model User {
  id        Int          @id @default(autoincrement())
  name      String       @db.VarChar(150)
  email     String       @unique @db.VarChar(255)
  photo     String?
  cover     String?
  role      UserRole     @default(USER)
  location  String?
  isActive  Boolean      @default(true)
  provider  AuthProvider @default(local)
  providerId String?     @db.VarChar(255)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  password  String

  // Relations
  stats             UserStats?
  activities        UserActivity[]
  watchlists        Watchlist[]
  transactions      Transaction[]
  sellerRequests    SellerRequest[]    @relation("SellerRequestUser")
  reviewedRequests  SellerRequest[]    @relation("SellerRequestReviewer")
  tokens            UserToken[]
  auctions          Auction[]
  bids              Bid[]
  liveBids          LiveBid[]
  endedAuctionWins  EndedAuction[]
  payments          Payment[]
  sentMessages      Message[]          @relation("MessageSender")
  receivedMessages  Message[]          @relation("MessageReceiver")
  notifications     Notification[]     @relation("NotificationRecipient")
  relatedNotifications Notification[]  @relation("NotificationRelatedUser")
  reactions         AuctionReaction[]
  announcements     Announcement[]
  blogs             Blog[]
  reportsSubmitted  Report[]           @relation("ReportReporter")
  reportsReceived   Report[]           @relation("ReportedUser")

  @@unique([provider, providerId])
  @@index([role])
  @@index([isActive])
  @@index([providerId])
  @@map("users")
}

model UserStats {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  accountBalance Decimal  @default(0) @db.Decimal(14, 2)
  auctionsWon    Int      @default(0)
  activeBids     Int      @default(0)
  totalSpent     Decimal  @default(0) @db.Decimal(14, 2)
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("user_stats")
}

model UserActivity {
  id           Int          @id @default(autoincrement())
  userId       Int
  activityType ActivityType
  description  String?
  metadata     Json?
  createdAt    DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([activityType])
  @@index([createdAt])
  @@map("user_activity")
}

model Watchlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  auctionId Int
  addedAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  auction Auction @relation(fields: [auctionId], references: [id])

  @@unique([userId, auctionId])
  @@index([auctionId])
  @@map("watchlists")
}

model Transaction {
  id            Int             @id @default(autoincrement())
  userId        Int
  type          TransactionType
  amount        Decimal         @db.Decimal(14, 2)
  referenceType String?         @db.VarChar(50)
  referenceId   Int?
  note          String?
  createdAt     DateTime        @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([referenceType, referenceId])
  @@map("transactions")
}

model SellerRequest {
  id              Int                 @id @default(autoincrement())
  userId          Int
  status          SellerRequestStatus @default(pending)
  businessName    String?             @db.VarChar(255)
  contactPhone    String?             @db.VarChar(50)
  address         String?
  taxId           String?             @db.VarChar(100)
  additionalNotes String?
  reviewedBy      Int?
  reviewedAt      DateTime?
  createdAt       DateTime            @default(now())

  user     User  @relation("SellerRequestUser", fields: [userId], references: [id])
  reviewer User? @relation("SellerRequestReviewer", fields: [reviewedBy], references: [id])

  @@index([userId])
  @@index([status])
  @@map("seller_requests")
}

// =============================================
// AUTHENTICATION & TOKENS
// =============================================

model UserToken {
  id         Int       @id @default(autoincrement())
  userId     Int
  tokenType  TokenType @default(refresh)
  tokenHash  String    @unique @db.VarChar(255)
  deviceInfo Json?
  ipAddress  String?   @db.VarChar(45)
  userAgent  String?
  expiresAt  DateTime
  lastUsedAt DateTime  @default(now())
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  /// Inactive tokens (lastUsedAt > 7 days) should be cleaned via cron job

  @@index([userId])
  @@index([userId, tokenType])
  @@index([expiresAt])
  @@index([lastUsedAt])
  @@map("user_tokens")
}

// =============================================
// AUCTIONS & BIDDING
// =============================================

model Auction {
  id             Int           @id @default(autoincrement())
  title          String        @db.VarChar(255)
  description    String?
  sellerId       Int
  images         String[]
  category       String?       @db.VarChar(100)
  startingPrice  Decimal       @db.Decimal(12, 2)
  currentBid     Decimal       @default(0) @db.Decimal(12, 2)
  endTime        DateTime
  status         AuctionStatus @default(upcoming)
  deliveryStatus String?       @db.VarChar(50)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  seller        User              @relation(fields: [sellerId], references: [id])
  bids          Bid[]
  liveBids      LiveBid[]
  endedAuction  EndedAuction?
  payments      Payment[]
  watchlists    Watchlist[]
  reactions     AuctionReaction[]
  notifications Notification[]
  reports       Report[]

  @@index([sellerId])
  @@index([endTime])
  @@index([status])
  @@index([category])
  @@index([status, endTime])
  @@map("auctions")
}

model Bid {
  id        Int      @id @default(autoincrement())
  auctionId Int
  userId    Int
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([auctionId])
  @@index([userId])
  @@index([auctionId, amount])
  @@index([auctionId, createdAt])
  @@map("bids")
}

/// Short-lived feed for real-time UI; purged after auction ends
model LiveBid {
  id        Int      @id @default(autoincrement())
  auctionId Int
  userId    Int?
  name      String?  @db.VarChar(100)
  photo     String?
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([auctionId])
  @@index([createdAt])
  @@map("live_bids")
}

model EndedAuction {
  id                Int      @id @default(autoincrement())
  originalAuctionId Int      @unique
  winnerId          Int?
  finalPrice        Decimal  @db.Decimal(12, 2)
  endedAt           DateTime @default(now())

  auction Auction @relation(fields: [originalAuctionId], references: [id])
  winner  User?   @relation(fields: [winnerId], references: [id])

  @@index([winnerId])
  @@map("ended_auctions")
}

// =============================================
// PAYMENTS & FINANCIALS
// =============================================

model Payment {
  id                 Int           @id @default(autoincrement())
  trxId              String        @unique @db.VarChar(100)
  auctionId          Int?
  buyerId            Int?
  amount             Decimal       @db.Decimal(12, 2)
  serviceFee         Decimal?      @db.Decimal(10, 2)
  status             PaymentStatus @default(pending)
  paymentGatewayData Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  auction Auction? @relation(fields: [auctionId], references: [id])
  buyer   User?    @relation(fields: [buyerId], references: [id])

  @@index([auctionId])
  @@index([buyerId])
  @@index([status])
  @@map("payments")
}

// =============================================
// SOCIAL & MESSAGING
// =============================================

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  text       String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("MessageSender", fields: [senderId], references: [id])
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id])

  @@index([senderId, receiverId])
  @@index([receiverId])
  @@index([createdAt])
  @@map("messages")
}

model Notification {
  id               Int      @id @default(autoincrement())
  recipientId      Int?
  title            String?  @db.VarChar(200)
  message          String?
  type             String?  @db.VarChar(50)
  relatedAuctionId Int?
  relatedUserId    Int?
  isRead           Boolean  @default(false)
  createdAt        DateTime @default(now())

  recipient     User?    @relation("NotificationRecipient", fields: [recipientId], references: [id])
  relatedUser   User?    @relation("NotificationRelatedUser", fields: [relatedUserId], references: [id])
  relatedAuction Auction? @relation(fields: [relatedAuctionId], references: [id])

  @@index([recipientId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model AuctionReaction {
  id        Int          @id @default(autoincrement())
  auctionId Int
  userId    Int
  reaction  ReactionType
  createdAt DateTime     @default(now())

  auction Auction @relation(fields: [auctionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([auctionId, userId])
  @@index([auctionId])
  @@map("auction_reactions")
}

// =============================================
// CONTENT & ADMIN
// =============================================

model Announcement {
  id        Int       @id @default(autoincrement())
  userId    Int
  title     String    @db.VarChar(255)
  content   String
  image     String?
  date      DateTime?
  createdAt DateTime  @default(now())

  author User @relation(fields: [userId], references: [id])

  @@map("announcements")
}

model Blog {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  authorId    Int
  imageUrls   String[]
  fullContent String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User      @relation(fields: [authorId], references: [id])
  tags   BlogTag[]

  @@index([authorId])
  @@map("blogs")
}

model BlogTag {
  id     Int    @id @default(autoincrement())
  blogId Int
  tag    String @db.VarChar(100)

  blog Blog @relation(fields: [blogId], references: [id])

  @@index([blogId])
  @@index([tag])
  @@map("blog_tags")
}

model Report {
  id             Int          @id @default(autoincrement())
  reporterId     Int
  reportedUserId Int?
  auctionId      Int?
  reason         String?
  description    String?
  status         ReportStatus @default(pending)
  createdAt      DateTime     @default(now())

  reporter     User     @relation("ReportReporter", fields: [reporterId], references: [id])
  reportedUser User?    @relation("ReportedUser", fields: [reportedUserId], references: [id])
  auction      Auction? @relation(fields: [auctionId], references: [id])

  @@index([reporterId])
  @@index([status])
  @@index([auctionId])
  @@map("reports")
}